# ============================================================
# ELECTRO STORE — ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to version control
# ============================================================

# --- DATABASE (PostgreSQL) ---
# Free options: https://neon.tech  |  https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/electro_store?sslmode=require"

# --- NEXTAUTH ---
# Generate secret:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- STRIPE ---
# Dashboard: https://dashboard.stripe.com/apikeys
# Webhook:   https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- APP URL (used in Stripe redirect URLs) ---
NEXT_PUBLIC_URL="http://localhost:3000"
